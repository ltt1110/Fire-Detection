# ============================================================
# 🔥 Fire Detection System - Environment Configuration
# ============================================================
# Copy file này thành .env và điền vào các giá trị thực
# KHÔNG commit file .env lên git!
# ============================================================

# ---- Telegram Bot Alert ----
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_COOLDOWN=20

# ---- Elasticsearch ----
ES_HOST=localhost
ES_PORT=9200
ES_INDEX=fire-detection-events

# ---- Flask Server ----
FLASK_PORT=8085
FLASK_DEBUG=true

# ---- Fire Detection ----
FIRE_THRESHOLD=0.55
FIRE_CONFIRMATION_FRAMES=5
MIN_FIRE_AREA_RATIO=0.02

# ---- Camera ----
# Đặt số (0,1,2...) để chỉ định camera cụ thể, hoặc "auto" để tự tìm
CAMERA_ID=auto
CAMERA_LOCATION=Camera AI - Hà Nội
